# QuantSpec environment template
# Copy to .env for local use. Do not commit real secrets.

# Optional. Required only for --llm-mode live.
ANTHROPIC_API_KEY=

# Optional live LLM settings.
QUANTSPEC_CLAUDE_MODEL=claude-sonnet-4-5-20250929
QUANTSPEC_HTTP_TIMEOUT_S=120
QUANTSPEC_LLM_MAX_RETRIES=2
QUANTSPEC_PROMPTS_VERSION=1.0.0

# Default mode for local CLI wrappers: fixture or live.
QUANTSPEC_LLM_MODE=fixture
